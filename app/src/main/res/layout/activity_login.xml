<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/darkBrown">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="60dp"
            android:paddingBottom="32dp">

            <!-- Logo + Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕"
                android:textSize="64sp"
                android:layout_gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/stash"
                android:text="Coffee Shop"
                android:textColor="@color/lightBrown"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:text="Welcome back! Sign in to continue"
                android:textColor="@color/lightBrown"
                android:textSize="13sp" />

            <!-- Card form -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:background="@drawable/brown_2_full_corner_bg"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="@color/lightBrown"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/emailInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/brown_full_corner_bg"
                    android:hint="Enter your email"
                    android:inputType="textEmailAddress"
                    android:padding="14dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/brown2"
                    android:textSize="14sp" />

                <!-- Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Password"
                    android:textColor="@color/lightBrown"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/passwordInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/brown_full_corner_bg"
                    android:hint="Enter your password"
                    android:inputType="textPassword"
                    android:padding="14dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/brown2"
                    android:textSize="14sp" />

                <!-- Error message -->
                <TextView
                    android:id="@+id/errorTxt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text=""
                    android:textColor="#FF6B6B"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <!-- Login Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/loginBtn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/brown_full_corner_bg"
                    android:text="Sign In"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/brown2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:text="Don't have an account?"
                    android:textColor="@color/lightBrown"
                    android:textSize="13sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/brown2" />
            </LinearLayout>

            <!-- Register Link -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/goToRegisterBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/stroke_bg"
                android:text="Create Account"
                android:textColor="@color/orange"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Guest mode -->
            <TextView
                android:id="@+id/continueAsGuestTxt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:padding="8dp"
                android:text="Continue as Guest →"
                android:textColor="@color/brown2"
                android:textSize="13sp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
